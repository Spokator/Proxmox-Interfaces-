# ===============================================================
# Chretieno.lan - Exemple de configuration environnement
# Copier ce fichier en .env puis adapter les valeurs
# ===============================================================

# Port de l'application
PORT=3000

# --- Proxmox API (obligatoire pour monitoring live) ---
PVE_HOST=192.168.8.100
PVE_PORT=8006
PVE_TOKEN_ID=chretieno@pve!intranet
PVE_TOKEN_SECRET=CHANGE_ME

# Watchers Proxmox (optionnel)
PVE_WATCH_TASKS_ENABLED=true
PVE_WATCH_SYSLOG_ENABLED=true
PVE_WATCH_INTERVAL_MS=20000

# --- Technitium DNS (optionnel pour auto-discovery améliorée) ---
TECHNITIUM_BASE_URL=http://192.168.8.150:5380
TECHNITIUM_TOKEN=
TECHNITIUM_USER=
TECHNITIUM_PASS=
TECHNITIUM_TOTP=
TECHNITIUM_ZONE_SUFFIX=.lan
