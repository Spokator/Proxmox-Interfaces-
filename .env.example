# ===============================================================
# Proxmox-Interfaces - Environment example
# Copy to .env and adjust all values for your target infra
# ===============================================================

# Port de l'application
PORT=3000

# --- Proxmox API (required for live inventory) ---
PVE_HOST=10.0.0.10
PVE_PORT=8006
PVE_TOKEN_ID=api-user@pve!proxmox-interfaces
PVE_TOKEN_SECRET=CHANGE_ME

# Watchers Proxmox (optionnel)
PVE_WATCH_TASKS_ENABLED=true
PVE_WATCH_SYSLOG_ENABLED=true
PVE_WATCH_INTERVAL_MS=20000

# --- Technitium DNS (optional for enhanced auto-discovery) ---
TECHNITIUM_BASE_URL=http://10.0.0.53:5380
TECHNITIUM_TOKEN=
TECHNITIUM_USER=
TECHNITIUM_PASS=
TECHNITIUM_TOTP=
TECHNITIUM_ZONE_SUFFIX=.internal
